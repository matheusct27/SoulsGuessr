<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SoulsGuessr</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Roboto+Condensed&display=swap" rel="stylesheet">
  </head>
<body>
  <button class="config-btn" onclick="abrirConfig()">
    <!-- Substitua o src pela sua imagem de engrenagem depois -->
    <img src="https://darksouls3.wiki.fextralife.com/file/Dark-Souls-3/bonewheel_shield.png" alt="Configurações" style="width:32px;height:32px;">
  </button>
  <header>
    <h1>SoulsGuessr</h1>
    <nav>
      <a href="/Bosses">Bosses</a>
      <a href="/Armas">Armas</a>
      <a href="/sobre">Sobre</a>
    </nav>
  </header>

  <main>
    <div class="main-center-container">
      <div class="custom-buttons-bar">
        <a href="/" class="custom-btn" title="Bosses">
          <img src="https://preview.redd.it/whats-everyones-favorite-boss-by-fight-design-or-lore-ill-v0-wkkqthslijec1.png?width=919&format=png&auto=webp&s=fdb8b657a33df20120ac90b78f401608759050a1" alt="Botão 1">
        </a>
        <a href="/armas" class="custom-btn" title="Armas">
          <img src="https://img.rankedboost.com/wp-content/uploads/2022/03/Elden-Ring-Dark-Moon-Greatsword.png" alt="Botão 2">
        </a>
        <a href="/Locais" class="custom-btn" title="Locais">
          <img src="https://i.redd.it/mo26tioaqom81.png" alt="Botão 3">
        </a>
        <a href="/OSTs" class="custom-btn" title="OSTs">
          <img src="https://www.models-resource.com/resources/big_icons/47/46958.png?updated=1624824360" alt="Botão 4">
        </a>
      </div>
      <div class="game-box">
        <div class="game-box-top">
          <span class="game-title">Adivinhe a arma de hoje!</span>
        </div>
        <div class="game-box-bottom">
          <input type="text" placeholder="Digite o nome..." />
          <button class="confirm-btn">
            <img src="https://static-00.iconduck.com/assets.00/send-icon-2048x1863-u8j8xnb6.png" alt="Confirmar" style="height:28px;width:28px;">
          </button>
        </div>
      </div>
      <div class="guess-table">
  <div class="guess-header">
    <div>Nome</div>
    <div>Jogo</div>
    <div>Tipo</div>
    <div>Local</div>
    <div>HP</div>
    <!-- Adicione mais categorias conforme desejar -->
  </div>
  <div class="guess-row">
    <div class="guess-cell correto">Artorias</div>
    <div class="guess-cell incorreto">DS2</div>
    <div class="guess-cell parcial">Humano</div>
    <div class="guess-cell incorreto">Anor Londo</div>
    <div class="guess-cell parcial">4000</div>
    <!-- Exemplo de preenchimento -->
  </div>
  <!-- Novas linhas aparecem a cada tentativa -->
</div>
    </div>
  </main>

  <!-- Botão de ajuda fixo no canto inferior direito -->
  <button class="ajuda-indicadores" onclick="abrirPopup()">?</button>

  <!-- Modal de explicação -->
  <div id="popup-indicadores" class="popup-indicadores">
    <div class="popup-conteudo">
      <span class="fechar" onclick="fecharPopup()">&times;</span>
      <h3>O que significa cada cor?</h3>
      <ul>
        <li><span class="indicador correto"></span> <b>Correto:</b> A resposta está certa!</li>
        <li><span class="indicador parcial"></span> <b>Parcial:</b> A resposta está parcialmente correta.</li>
        <li><span class="indicador incorreto"></span> <b>Incorreto:</b> A resposta está errada.</li>
      </ul>
    </div>
  </div>

  <!-- Modal de configurações -->
  <div id="popup-config" class="popup-indicadores">
    <div class="popup-conteudo">
      <span class="fechar" onclick="fecharConfig()">&times;</span>
      <h3>Configurações</h3>
      <!-- Coloque aqui as opções de configuração que desejar -->
      <p>Em breve...</p>
    </div>
  </div>

  <footer>
    <p>© 2025 SoulsGuessr. Inspirado em FromSoftware.</p>
  </footer>

  <script>
  function abrirPopup() {
    document.getElementById('popup-indicadores').classList.add('ativo');
  }
  function fecharPopup() {
    document.getElementById('popup-indicadores').classList.remove('ativo');
  }
  function abrirConfig() {
    document.getElementById('popup-config').classList.add('ativo');
  }
  function fecharConfig() {
    document.getElementById('popup-config').classList.remove('ativo');
  }
  // Fechar ao clicar fora do conteúdo
  window.onclick = function(event) {
    const popup = document.getElementById('popup-indicadores');
    if (event.target === popup) {
      fecharPopup();
    }
    const popupConfig = document.getElementById('popup-config');
    if (event.target === popupConfig) {
      fecharConfig();
    }
  }

  // Exemplo simples para adicionar uma linha (adicione ao seu JS)
function adicionarTentativa(tentativa) {
  const tabela = document.querySelector('.guess-table');
  const row = document.createElement('div');
  row.className = 'guess-row';
  row.innerHTML = `
    <div class="guess-cell ${tentativa.nomeStatus}">${tentativa.nome}</div>
    <div class="guess-cell ${tentativa.jogoStatus}">${tentativa.jogo}</div>
    <div class="guess-cell ${tentativa.tipoStatus}">${tentativa.tipo}</div>
    <div class="guess-cell ${tentativa.localStatus}">${tentativa.local}</div>
    <div class="guess-cell ${tentativa.hpStatus}">${tentativa.hp}</div>
  `;
  tabela.appendChild(row);
}

// Exemplo de uso:
adicionarTentativa({
  nome: 'Artorias', nomeStatus: 'correto',
  jogo: 'DS2', jogoStatus: 'incorreto',
  tipo: 'Humano', tipoStatus: 'parcial',
  local: 'Anor Londo', localStatus: 'incorreto',
  hp: '4000', hpStatus: 'parcial'
});
  </script>
</body>
</html>
